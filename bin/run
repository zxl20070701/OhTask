#!/usr/bin/env node

'use strict';

process.title = 'OhTask';

const Aidejs = require("@aidejs/core");
const Tools = require("@aidejs/tools");

const { logform } = require("oipage/nodejs/logform/index.js");

Aidejs.use(Tools);

let agent = new Aidejs({
    model: "qwen3"
});

agent.task(void 0, function (message) {
    process.stdout.write(message);
}, function () {
    return new Promise((resolve) => {

        logform([{
            type: "input",
            label: "请输入任务："
        }]).then(result => {
            resolve(result[0]);
        });

    });
});